# Використовуємо офіційний легкий образ Node.js
FROM node:18-slim

# Робоча директорія всередині контейнера
WORKDIR /app

# Спочатку копіюємо файли залежностей
COPY package*.json ./

# Встановлюємо бібліотеки
RUN npm install

# Копіюємо весь інший код (твій server.js)
COPY . .

# Відкриваємо порт 3000 для доступу зовні
EXPOSE 3000

# Запускаємо сервер
CMD ["node", "server.js"]